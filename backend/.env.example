# Database Configuration
DATABASE_URL=postgresql://user:pass@localhost:5432/workscan

# AI/LLM Configuration
# Option 1: Use Claude API (Anthropic)
ANTHROPIC_API_KEY=your_claude_api_key_here

# Option 2: Use OpenAI (uncomment if using OpenAI instead)
# OPENAI_API_KEY=your_openai_key_here

# Option 3: Use local Ollama (uncomment if using local LLM)
# OLLAMA_BASE_URL=http://localhost:11434

# Application Settings
ENVIRONMENT=development
DEBUG=True

# CORS Settings (for Next.js frontend)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Bot protection ────────────────────────────────────────────────────────────
MAX_ANALYSES_PER_HOUR=5
RECAPTCHA_SECRET_KEY=your_recaptcha_v3_secret_here
RECAPTCHA_MIN_SCORE=0.5

# ── Admin auth ────────────────────────────────────────────────────────────────
# The x-admin-secret for /api/admin/* and /api/cron/*. Generate a strong value:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Set the REAL value only in the environment (.env locally, Render in prod).
# Empty => all admin endpoints reject every request (fail closed).
ADMIN_SECRET=change_me_use_a_long_random_value

# ── Owner rate-limit bypass ───────────────────────────────────────────────────
# Comma-separated. Each entry may be an exact IP, a prefix ("84.59." / "84.59.*"),
# or "*". Prefix survives ISP IP reassignment. Empty => no bypass.
OWNER_IP=

# ── Persistent DB (Turso / libSQL) — prod ─────────────────────────────────────
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your_turso_token_here

# ── Email (Resend) + links ────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_key_here
FROM_EMAIL=noreply@workscanai.com
APP_URL=https://workscanai.vercel.app

# ── PostHog server-side analytics ─────────────────────────────────────────────
POSTHOG_API_KEY=phc_your_posthog_key_here
POSTHOG_HOST=https://eu.i.posthog.com
